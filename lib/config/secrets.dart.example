/// 민감한 키 모음 — 이 파일을 복사해서 secrets.dart 로 이름 변경 후 실제 키 입력
/// secrets.dart 는 .gitignore 에 등록되어 있어 Git에 올라가지 않습니다.
class AppSecrets {
  AppSecrets._();

  /// Telegram 봇 토큰 (직접배송 당첨 알림용)
  static const String telegramBotToken = 'YOUR_TELEGRAM_BOT_TOKEN';
  static const int telegramChatId = 0; // YOUR_CHAT_ID

  /// 카카오 네이티브 앱 키
  static const String kakaoNativeAppKey = 'YOUR_KAKAO_NATIVE_APP_KEY';
}
